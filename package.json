{
	"name": "filmroll",
	"version": "0.1.0",
	"type": "module",
	"description": "Extract meaningful frames from video files for AI review — CLI tool and MCP server",
	"main": "dist/lib.js",
	"module": "src/index.ts",
	"bin": {
		"filmroll": "src/cli/index.ts"
	},
	"scripts": {
		"dev": "bun run src/cli/index.ts",
		"test": "bun test",
		"build": "bun build src/cli/index.ts --outdir dist --target bun && bun build src/index.ts --outfile dist/lib.js --target bun"
	},
	"keywords": [
		"video",
		"frames",
		"ffmpeg",
		"slideshow",
		"mcp",
		"ai",
		"review"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"commander": "^14.0.3",
		"sharp": "^0.34.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"bun-types": "^1.3.11",
		"typescript": "^6.0.2"
	}
}
